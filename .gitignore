# ============================================================
# Elevator HMI — .gitignore
# ============================================================

# ------------------------------------------------------------
# Yocto build artefacts (never commit — they are gigabytes)
# ------------------------------------------------------------
build/tmp/
build/tmp-glibc/
build/downloads/
build/sstate-cache/
build/cache/
build/conf/
build/bitbake.lock
build/*.log

# Optional local copies of kas / bitbake stdout (see diary/PROGRESS.md)
build-logs/

# BitBake task logs
*.bb_log

# ------------------------------------------------------------
# Library — vendor PDFs and reference documents
# PDFs and other vendor binaries are NOT tracked in Git.
# Only generated .md conversions (scripts/convert-library.sh) ARE tracked.
# Image/Source/Tools directories from vendor USB drops are excluded.
# ------------------------------------------------------------

# Exclude everything in library/ by default...
library/**

# ...then allow directory traversal into EM3566 so git can find .md files
!library/EM3566/
!library/EM3566/**/

# ...and allow .md files specifically
!library/EM3566/**/*.md

# Re-ignore large binary directories (vendor firmware images and source — 70 GB+)
# These were unignored by the ** rule above; explicitly re-exclude them.
library/EM3566/Linux6.1/Image/
library/EM3566/Linux6.1/Source/
library/EM3566/Android14/Image/
library/EM3566/Android14/Source/
library/EM3566/Tools/

# Windows artifact from USB drive copy — never track
library/System Volume Information/

# ------------------------------------------------------------
# kas workspace directories (kas fetches these at build time)
# ------------------------------------------------------------
kas-build/
.kas-*

# Layer source directories fetched by kas (not our code)
# Exception: meta-hmi-platform and meta-hmi-app ARE tracked
poky/
meta-rockchip/
meta-qt6/
meta-rauc/
meta-openembedded/

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# ------------------------------------------------------------
# Editor and IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Build outputs (application, not Yocto)
# ------------------------------------------------------------
build-qt/
*.o
*.a
*.so
*.so.*
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ------------------------------------------------------------
# RAUC signing keys — NEVER commit private keys
# ------------------------------------------------------------
*.pem
*.key
*.p12
certs/private/
certs/*.pem
certs/*.key

# ------------------------------------------------------------
# OTA bundles (large, ephemeral)
# ------------------------------------------------------------
*.raucb

# ------------------------------------------------------------
# Logs and temporary files
# ------------------------------------------------------------
*.log
*.tmp
*.bak
.tmp/

# ------------------------------------------------------------
# CI / test artefacts
# ------------------------------------------------------------
coverage/
test-results/
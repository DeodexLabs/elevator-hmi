# Elevator HMI — eMMC layout (Phase 1 bring-up sizes)
#
# BRING-UP NOTE: Partition sizes reduced for reliable flashing via
# rkdeveloptool. Production sizes: rootfs 2048M, data 4096M.
# Expand after first boot is confirmed working.
#
# A/B RAUC intent: rootfs_b is empty at factory — RAUC update target.
# data partition is never erased by OTA.

part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label boot --active --align 4 --size 64M
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfs_a --align 4 --size 1024M
part --ondisk mmcblk0 --fstype=ext4 --label rootfs_b --align 4 --size 1024M
part /data --ondisk mmcblk0 --fstype=ext4 --label data --align 4 --size 512M
